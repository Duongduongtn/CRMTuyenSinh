# Base URL của BE Django REST API.
# Dev: rỗng → axios dùng path tương đối /api/* và Vite proxy sang :8000.
# Prod: https://crm.tencongty.vn (cùng origin, không cần CORS).
VITE_API_BASE=

# Sentry observability (tùy chọn).
# DSN trống → SDK no-op, không ảnh hưởng dev. Mở tài khoản Sentry free
# (https://sentry.io) → tạo project Vue → copy DSN paste vào đây.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
