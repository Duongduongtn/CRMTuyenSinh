# ============================================================
# CRM Tuyen Sinh - env prod template
# Copy file nay thanh .env.prod tren VPS (KHONG commit .env.prod thuc te).
#
# Sinh SECRET_KEY 64 byte random:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================

# ----- Django core -----
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=REPLACE_WITH_TOKEN_URLSAFE_64_BYTES
DJANGO_ALLOWED_HOSTS=sale.trungtamthanhdat.com,127.0.0.1,localhost

# ----- Domain layout -----
BASE_DOMAIN=trungtamthanhdat.com
SITE_PUBLIC_URL=https://trungtamthanhdat.com
SITE_STUDENT_URL=https://hocvien.trungtamthanhdat.com
SITE_CRM_URL=https://sale.trungtamthanhdat.com

# CORS / CSRF whitelist (cong + giua dau phay).
DJANGO_CORS_ORIGINS=https://trungtamthanhdat.com,https://hocvien.trungtamthanhdat.com,https://sale.trungtamthanhdat.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://sale.trungtamthanhdat.com,https://hocvien.trungtamthanhdat.com,https://trungtamthanhdat.com

# ----- Postgres (compose service `db`) -----
POSTGRES_DB=crm_thanhdat
POSTGRES_USER=crm_thanhdat
# Sinh password 32+ ky tu, KHONG dung ky tu dac biet phai escape URL (@, :, /, #, ?).
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_32_CHARS
# DATABASE_URL phai khop voi POSTGRES_* phia tren.
DATABASE_URL=postgres://crm_thanhdat:REPLACE_WITH_STRONG_RANDOM_32_CHARS@db:5432/crm_thanhdat

# ----- Redis + Celery (compose service `redis`) -----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# ----- SSL / security -----
DJANGO_SECURE_SSL_REDIRECT=True
# HSTS 30 ngay. Sau khi chac chan khong rollback HTTPS, tang len 1 nam + bat HSTS_PRELOAD trong code.
DJANGO_HSTS_SECONDS=2592000
# Bat khi VPS dung sau nginx (xac nhan X-Forwarded-For tu nginx host, khong tu client).
TRUST_X_FORWARDED_FOR=True
DJANGO_CSP_REPORT_ONLY=False

# ----- Fernet encryption cho IntegrationCredential -----
# Sinh KEY 1 LAN:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Mat KEY = mat toan bo credential trong DB. Backup vao password manager (1Password/Bitwarden).
# Khi rotate: paste KEY moi vao FERNET_SECRET, dau cu vao FERNET_SECRET_OLD (csv).
FERNET_SECRET=REPLACE_WITH_FERNET_KEY_44_CHARS
FERNET_SECRET_OLD=

# ----- Casso (doi soat QR thanh toan) -----
# Tu Sprint 3 Tuan 7: 4 nhom key duoi paste qua UI CRM /admin/integrations
# (luu vao DB ma hoa Fernet). Cac field nay van duoc giu lam fallback khi DB
# chua co credential (boot dau, hoac DB roi).
CASSO_WEBHOOK_SECRET=
CASSO_API_KEY=

# ----- Zalo ZNS (OTP hoc vien) -----
# ZNS_ALLOW_MOCK da hard-code False trong prod.py. Cac field duoi BAT BUOC co.
ZNS_ACCESS_TOKEN=
ZNS_REFRESH_TOKEN=
ZNS_TEMPLATE_ID_OTP=
ZNS_TEMPLATE_ID_DEPOSIT=

# ----- Telegram (alert sale khi co lead moi) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Facebook Lead Ads webhook -----
FB_APP_SECRET=
FB_LEAD_VERIFY_TOKEN=
# KHONG bat o prod du chi 1 lan.
FB_ALLOW_INSECURE_DEV=False

# ----- Email SMTP (thong bao noi bo) -----
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ----- Sentry observability (tuy chon) -----
# DSN trong = SDK no-op, deploy van chay binh thuong. Mo tai khoan Sentry free
# (https://sentry.io) -> tao 2 project (Django + Vue) -> paste DSN tuong ung.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE de trong se duoc CI/CD inject git SHA sau (workflow extension).
SENTRY_RELEASE=
