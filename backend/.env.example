# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod-please-use-50-random-chars
# AE6: prod bắt buộc set RIÊNG, không fallback về DJANGO_SECRET_KEY.
# Dev có thể bỏ trống → tự fallback. Sinh bằng: python -c "import secrets; print(secrets.token_urlsafe(64))"
STUDENT_JWT_SECRET=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Domain (placeholder, đổi khi mua tên miền thật)
BASE_DOMAIN=tencongty.vn
SITE_PUBLIC_URL=http://localhost:3000
SITE_STUDENT_URL=http://localhost:3001
SITE_CRM_URL=http://localhost:8000

# Database
# Để trống → mặc định SQLite db.sqlite3 cho dev nhanh
# Khi có Postgres, set:
# DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/crm_tuyensinh_dev
DATABASE_URL=

# Redis + Celery (để trống ở dev → Celery chạy eager sync)
REDIS_URL=
CELERY_BROKER_URL=
CELERY_TASK_ALWAYS_EAGER=True

# Casso (Sprint 1 sẽ dùng)
CASSO_WEBHOOK_SECRET=
CASSO_API_KEY=

# Zalo ZNS (Sprint 2 sẽ dùng)
ZNS_ACCESS_TOKEN=
ZNS_REFRESH_TOKEN=
ZNS_TEMPLATE_ID_OTP=
ZNS_TEMPLATE_ID_DEPOSIT=

# Telegram bot (cho alert sale khi có lead mới)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sentry observability (tùy chọn, chỉ kích hoạt khi prod có DSN)
# Mở tài khoản Sentry free → tạo project Django → copy DSN.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
